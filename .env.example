# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit the real file.

# Password shown on the login gate. Leave blank to disable the gate entirely.
SITE_PASSWORD=ChangeMe

# S3 bucket name for deployment (must be globally unique)
S3_BUCKET=d7-schedule-2026

# AWS region for the S3 bucket (default: us-east-1)
AWS_REGION=us-east-1
